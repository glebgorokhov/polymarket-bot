# Polymarket CLOB credentials
RELAYER_API_KEY=your_relayer_api_key_here
RELAYER_API_ADDRESS=0xYourRelayerAddress
SIGNER_ADDRESS=0xYourSignerAddress

# Database
DATABASE_URL=postgresql+asyncpg://polymarket:yourpassword@db:5432/polymarket_bot
POSTGRES_PASSWORD=yourpassword

# Telegram bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_ID=123456789

# Optional defaults (can also be set via /budget, /pertrade, /maxtrade commands)
DEFAULT_BUDGET_TOTAL=50.0
DEFAULT_PER_TRADE_PCT=5.0
DEFAULT_MAX_TRADE_USD=20.0
